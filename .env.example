# Environment Variables for Auction Platform (Vercel Deployment)

# ===========================================
# IMPORTANT: For Vercel deployment, set these
# variables in your Vercel project dashboard,
# NOT in a .env file
# ===========================================

# Server Configuration
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/auctiondb?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_here
JWT_EXPIRE=7d
COOKIE_EXPIRE=7

# Email Configuration (Gmail SMTP)
SMTP_SERVICE=gmail
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (for CORS - update with your Vercel frontend URL)
FRONTEND_URL=https://your-frontend-project.vercel.app

# Vercel-specific settings
ENABLE_CRON=false

# ===========================================
# SETUP INSTRUCTIONS FOR VERCEL
# ===========================================

# 1. Go to your Vercel project dashboard
# 2. Navigate to Settings > Environment Variables
# 3. Add each variable listed above
# 4. Replace placeholder values with your actual credentials

# Gmail Setup:
# - Use your Gmail address for SMTP_MAIL
# - Generate an App Password: https://support.google.com/accounts/answer/185833
# - Use the App Password (not your regular password) for SMTP_PASSWORD

# MongoDB Atlas:
# - Create cluster at https://www.mongodb.com/atlas
# - Get connection string and replace username/password
# - IMPORTANT: Whitelist IP to 0.0.0.0/0 for Vercel

# Cloudinary:
# - Sign up at https://cloudinary.com
# - Get your cloud name, API key, and API secret from dashboard

# JWT Secret:
# - Generate a secure random string (at least 32 characters)
# - Use online generators or: openssl rand -base64 32

# Frontend URL:
# - After deploying frontend to Vercel, update this with the actual URL
# - Example: https://auction-frontend.vercel.app

# JWT Secret:
# - Generate a secure random string (at least 32 characters)
# - Use online generators or: openssl rand -base64 32